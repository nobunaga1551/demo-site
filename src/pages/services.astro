---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "画像処理アルゴリズム構築",
    description: "要件をヒアリングさせていただき、最適なアルゴリズムを構築いたします。",
    price: "¥10,000〜",
  },
  {
    title: "webサイト構築",
    description: "個人事業主、開業したい方向けにホームページを作成いたします。",
    price: "¥5,000",
  },
  {
    title: "DevOps環境構築",
    description: "ビルド環境の改善を行い、開発効率の向上を支援いたします。",
    price: "¥15,000〜",
  },
];
---

<Layout title="サービス">
  <section class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">サービス</h1>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <div class="border border-gray-200 rounded-xl p-6">
          <h2 class="text-lg font-bold mb-2">{s.title}</h2>
          <p class="text-gray-600 mb-4">{s.description}</p>
          <p class="font-bold text-gray-800">{s.price}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>