---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "画像処理アルゴリズム構築",
    description: "要件をヒアリングさせていただき、最適なアルゴリズムを構築いたします。",
    price: "¥10,000〜",
  },
  {
    title: "webサイト構築",
    description: "個人事業主、開業したい方向けにホームページを作成いたします。",
    price: "¥5,000",
  },
  {
    title: "DevOps環境構築",
    description: "ビルド環境の改善を行い、開発効率の向上を支援いたします。",
    price: "¥15,000〜",
  },
];
---

<Layout title="サービス">
  <section class="services">
    <h1>サービス</h1>
    <div class="cards">
      {services.map((s) => (
        <div class="card">
          <h2>{s.title}</h2>
          <p>{s.description}</p>
          <p class="price">{s.price}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .services {
    max-width: 900px;
    margin: 0 auto;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .card {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .price {
    font-weight: bold;
    color: #333;
    margin-top: 1rem;
  }
</style>