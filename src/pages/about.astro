---
import Layout from '../layouts/Layout.astro';
---

<Layout title="プロフィール">
  <section class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">プロフィール</h1>

    <div class="flex gap-8 items-start mb-12">
      <img src="/profile.jpg" alt="プロフィール写真"
        class="w-40 h-40 rounded-full object-cover shrink-0" />
      <div>
        <h2 class="text-2xl font-bold mb-2">Your Name</h2>
        <p class="text-gray-500 mb-2">職種・肩書きをここに書く</p>
        <p class="text-gray-600">自己紹介文をここに書く。経歴や得意なことなど。</p>
      </div>
    </div>

    <div>
      <h2 class="text-2xl font-bold border-b-2 border-gray-800 pb-2 mb-4">スキル</h2>
      <ul class="flex gap-3 flex-wrap list-none p-0">
        <li class="bg-gray-100 px-4 py-1 rounded-full">webデザイナー</li>
        <li class="bg-gray-100 px-4 py-1 rounded-full">画像処理エンジニア</li>
        <li class="bg-gray-100 px-4 py-1 rounded-full">クラウドエンジニア</li>
      </ul>
    </div>
  </section>
</Layout>