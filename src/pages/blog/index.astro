---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';
import type { Blog } from '../../lib/microcms';

const { contents } = await client.getList<Blog>({ endpoint: 'blogs' });
---

<Layout title="ブログ">
  <section class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">ブログ</h1>

    <ul class="flex flex-col gap-6">
      {contents.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="flex gap-4 items-start hover:opacity-70 transition-opacity">
            {post.thumbnail && (
              <img src={post.thumbnail.url} alt={post.title}
                class="w-24 h-24 object-cover rounded shrink-0" />
            )}
            <div>
              <h2 class="text-xl font-bold mb-1">{post.title}</h2>
              <p class="text-gray-500 text-sm">
                {new Date(post.createdAt).toLocaleDateString('ja-JP')}
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>