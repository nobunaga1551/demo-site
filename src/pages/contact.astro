---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ">
  <section class="max-w-xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">お問い合わせ</h1>

    <form action="https://formspree.io/f/mbdpvgod" method="POST">
      <p class="text-gray-600 mb-6">お気軽にご連絡ください。通常2営業日以内にご返信します。</p>

      <div class="flex flex-col gap-2 mb-6">
        <label for="name" class="font-bold">お名前</label>
        <input type="text" id="name" name="name" required
          class="border border-gray-300 rounded px-3 py-2 text-base w-full" />
      </div>

      <div class="flex flex-col gap-2 mb-6">
        <label for="email" class="font-bold">メールアドレス</label>
        <input type="email" id="email" name="email" required
          class="border border-gray-300 rounded px-3 py-2 text-base w-full" />
      </div>

      <div class="flex flex-col gap-2 mb-6">
        <label for="message" class="font-bold">メッセージ</label>
        <textarea id="message" name="message" rows="6" required
          class="border border-gray-300 rounded px-3 py-2 text-base w-full"></textarea>
      </div>

      <button type="submit"
        class="bg-gray-800 text-white px-8 py-3 rounded hover:bg-gray-600 transition-colors cursor-pointer">
        送信する
      </button>
    </form>
  </section>

  <script>
    (async () => {
      const form = document.querySelector('form');
      if (!(form instanceof HTMLFormElement)) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        });
        if (res.ok) {
          form.innerHTML = '<p class="text-green-600 bg-green-50 p-4 rounded">送信しました。2営業日以内にご返信します。</p>';
        } else {
          form.innerHTML = '<p class="text-red-600 bg-red-50 p-4 rounded">送信に失敗しました。時間をおいて再度お試しください。</p>';
        }
      });
    })();
  </script>
</Layout>