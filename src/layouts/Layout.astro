---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-gray-800 text-white px-4 py-4">
      <nav class="flex gap-4">
        <a href="/" class="hover:underline text-sm">トップ</a>
        <a href="/about" class="hover:underline text-sm">プロフィール</a>
        <a href="/services" class="hover:underline text-sm">サービス</a>
        <a href="/contact" class="hover:underline text-sm">お問い合わせ</a>
      </nav>
    </header>

    <main class="flex-1 p-8">
      <slot />
    </main>

    <footer class="bg-gray-800 text-white text-center py-4">
      <p>&copy; 2026 Your Name</p>
    </footer>
  </body>
</html>