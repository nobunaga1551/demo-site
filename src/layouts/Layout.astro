---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
    <header>
      <nav>
        <a href="/">トップ</a>
        <a href="/about">プロフィール</a>
        <a href="/services">サービス</a>
        <a href="/contact">お問い合わせ</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; 2026 Your Name</p>
    </footer>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    font-family: sans-serif;
  }

  header {
    padding: 1rem 2rem;
    background: #333;
    color: white;
  }

  nav a {
    color: white;
    text-decoration: none;
    margin-right: 1.5rem;
  }

  nav a:hover {
    text-decoration: underline;
  }

  main {
    padding: 2rem;
  }

  footer {
    padding: 1rem 2rem;
    background: #333;
    color: white;
    text-align: center;
  }
</style>
